{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://journium.app/schemas/journium-insight-tracker.v0Beta.schema.json",
  "title": "Journium InsightTracker v0Beta",
  "allOf": [
    { "$ref": "https://journium.app/schemas/journium-insight-tracker.base.schema.json" },
    {
      "type": "object",
      "required": ["apiVersion", "spec"],
      "properties": {
        "apiVersion": { "const": "journium.app/v0Beta" },
        "spec": { "$ref": "#/$defs/Spec" }
      }
    }
  ],
  "$defs": {
    "Spec": {
      "type": "object",
      "required": ["type", "trigger", "window", "analysis", "llm"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "LLM" },
        "trigger":  { "$ref": "#/$defs/Trigger" },
        "window":   { "$ref": "#/$defs/Window" },
        "analysis": { "$ref": "#/$defs/Analysis" },
        "llm":      { "$ref": "#/$defs/LLMConfig" },
        "privacy":  { "$ref": "#/$defs/Privacy" }
      }
    },

    "Trigger": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["automatic", "manual"] },
        "schedule": {
          "oneOf": [
            { "enum": ["hourly", "daily", "weekly", "monthly"] },
            {
              "type": "object",
              "required": ["cron"],
              "additionalProperties": false,
              "properties": {
                "cron": { "type": "string", "minLength": 7, "maxLength": 100 }
              }
            }
          ]
        }
      },
      "if":   { "properties": { "mode": { "const": "automatic" } }, "required": ["mode"] },
      "then": { "required": ["schedule"] }
    },

    "Window": {
      "type": "object",
      "required": ["period"],
      "additionalProperties": false,
      "properties": {
        "period": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "last_1d", "last_7d", "last_14d", "last_30d",
                "last_60d", "last_90d", "last_180d", "last_365d"
              ]
            },
            {
              "type": "object",
              "required": ["start", "end"],
              "additionalProperties": false,
              "properties": {
                "start": { "type": "string" },
                "end":   { "type": "string" }
              }
            }
          ]
        },
        "granularity": { "enum": ["hour", "day", "week", "month"] },
        "timezone":    { "type": "string", "default": "UTC" }
      }
    },

    "PropertyFilter": {
      "type": "object",
      "required": ["property", "operator", "value"],
      "additionalProperties": false,
      "properties": {
        "property": { "type": "string", "minLength": 1, "maxLength": 100 },
        "operator": {
          "enum": [
            "eq", "neq", "in", "not_in",
            "contains", "not_contains",
            "gt", "gte", "lt", "lte",
            "is_null", "is_not_null"
          ]
        },
        "value": {}
      }
    },

    "BreakdownDef": {
      "type": "object",
      "required": ["property"],
      "additionalProperties": false,
      "properties": {
        "property":       { "type": "string" },
        "maxCardinality": { "type": "integer", "minimum": 2, "maximum": 20, "default": 5 }
      }
    },

    "Analysis": {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "type": "string" } },
      "oneOf": [
        { "$ref": "#/$defs/FunnelAnalysis" },
        { "$ref": "#/$defs/RetentionAnalysis" },
        { "$ref": "#/$defs/ActivationAnalysis" },
        { "$ref": "#/$defs/ChurnAnalysis" },
        { "$ref": "#/$defs/FeatureAdoptionAnalysis" },
        { "$ref": "#/$defs/AnomalyAnalysis" },
        { "$ref": "#/$defs/ConversionAnalysis" },
        { "$ref": "#/$defs/CohortAnalysis" },
        { "$ref": "#/$defs/CustomAnalysis" }
      ]
    },

    "FunnelAnalysis": {
      "type": "object",
      "required": ["type", "steps"],
      "additionalProperties": false,
      "properties": {
        "type":   { "const": "funnel" },
        "entity": { "enum": ["person_id", "session_id", "device_id"], "default": "person_id" },
        "steps": {
          "type": "array",
          "minItems": 2,
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["event", "label"],
            "additionalProperties": false,
            "properties": {
              "event":   { "type": "string", "minLength": 1, "maxLength": 200 },
              "label":   { "type": "string", "minLength": 1, "maxLength": 100 },
              "filters": { "type": "array", "items": { "$ref": "#/$defs/PropertyFilter" }, "maxItems": 10 }
            }
          }
        },
        "conversionWindow": { "type": "string", "pattern": "^[0-9]+(m|h|d)$" },
        "breakdowns":       { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/BreakdownDef" } },
        "globalFilters":    { "type": "array", "items": { "$ref": "#/$defs/PropertyFilter" }, "maxItems": 5 }
      }
    },

    "RetentionAnalysis": {
      "type": "object",
      "required": ["type", "cohortEvent", "retentionEvent", "intervals"],
      "additionalProperties": false,
      "properties": {
        "type":           { "const": "retention" },
        "entity":         { "enum": ["person_id"], "default": "person_id" },
        "cohortEvent":    { "type": "string" },
        "retentionEvent": { "type": "string" },
        "cohortPeriod":   { "enum": ["day", "week", "month"], "default": "week" },
        "intervals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "type": "integer", "minimum": 1, "maximum": 365 }
        },
        "minCohortSize":  { "type": "integer", "minimum": 1, "default": 5 },
        "maxCohorts":     { "type": "integer", "minimum": 1, "maximum": 52, "default": 12 }
      }
    },

    "ActivationAnalysis": {
      "type": "object",
      "required": ["type", "startEvent", "ahaEvent", "activationWindow"],
      "additionalProperties": false,
      "properties": {
        "type":             { "const": "activation" },
        "entity":           { "enum": ["person_id"], "default": "person_id" },
        "startEvent":       { "type": "string" },
        "ahaEvent":         { "type": "string" },
        "activationWindow": { "type": "string", "pattern": "^[0-9]+(h|d)$" },
        "compareWindow":    { "enum": ["previous_period"] },
        "breakdowns":       { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/BreakdownDef" } }
      }
    },

    "ChurnAnalysis": {
      "type": "object",
      "required": ["type", "activeEvent", "inactivityThreshold"],
      "additionalProperties": false,
      "properties": {
        "type":                { "const": "churn" },
        "entity":              { "enum": ["person_id"], "default": "person_id" },
        "activeEvent":         { "type": "string" },
        "lookbackPeriod":      { "type": "string", "pattern": "^[0-9]+d$", "default": "30d" },
        "inactivityThreshold": { "type": "string", "pattern": "^[0-9]+d$" },
        "segments": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["property"],
            "additionalProperties": false,
            "properties": { "property": { "type": "string" } }
          }
        },
        "metrics": {
          "type": "array",
          "items": { "enum": ["atRiskCount", "atRiskRate", "segmentBreakdown", "timeSeriesTrend"] }
        }
      }
    },

    "FeatureAdoptionAnalysis": {
      "type": "object",
      "required": ["type", "featureEvents", "activeUserBaseline"],
      "additionalProperties": false,
      "properties": {
        "type":   { "const": "featureAdoption" },
        "entity": { "enum": ["person_id"], "default": "person_id" },
        "featureEvents": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["event"],
            "additionalProperties": false,
            "properties": {
              "event":   { "type": "string" },
              "label":   { "type": "string" },
              "filters": { "type": "array", "items": { "$ref": "#/$defs/PropertyFilter" }, "maxItems": 5 }
            }
          }
        },
        "activeUserBaseline": {
          "type": "object",
          "required": ["event"],
          "additionalProperties": false,
          "properties": {
            "event":  { "type": "string" },
            "period": { "type": "string" }
          }
        },
        "breakdowns":    { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/BreakdownDef" } },
        "metrics": {
          "type": "array",
          "items": { "enum": ["uniqueAdopters", "adoptionRate", "avgUsesPerAdopter", "weekOverWeekDelta", "monthOverMonthDelta"] }
        },
        "compareWindow": { "enum": ["previous_period"] }
      }
    },

    "AnomalyAnalysis": {
      "type": "object",
      "required": ["type", "metrics", "baseline", "threshold"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "anomaly" },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["event", "aggregation", "groupBy"],
            "additionalProperties": false,
            "properties": {
              "event":       { "type": "string" },
              "aggregation": { "enum": ["count", "uniqueUsers", "sum", "avg"] },
              "label":       { "type": "string" },
              "groupBy":     { "enum": ["hour", "day", "week"] },
              "sumProperty": { "type": "string" },
              "filters":     { "type": "array", "items": { "$ref": "#/$defs/PropertyFilter" }, "maxItems": 5 }
            }
          }
        },
        "baseline": {
          "type": "object",
          "required": ["type", "windowDays"],
          "additionalProperties": false,
          "properties": {
            "type":       { "enum": ["rolling_average", "same_period_last_week", "same_period_last_month"] },
            "windowDays": { "type": "integer", "minimum": 3, "maximum": 90 }
          }
        },
        "threshold": {
          "type": "object",
          "required": ["stdDeviations"],
          "additionalProperties": false,
          "properties": {
            "stdDeviations":     { "type": "number", "minimum": 1.0, "maximum": 5.0 },
            "minAbsoluteChange": { "type": "integer", "minimum": 1 }
          }
        },
        "includeTimeSeries": { "type": "boolean", "default": false }
      }
    },

    "ConversionAnalysis": {
      "type": "object",
      "required": ["type", "numeratorEvent", "denominatorEvent"],
      "additionalProperties": false,
      "properties": {
        "type":               { "const": "conversion" },
        "entity":             { "enum": ["person_id", "session_id"], "default": "person_id" },
        "numeratorEvent":     { "type": "string" },
        "denominatorEvent":   { "type": "string" },
        "conversionWindow":   { "type": "string", "pattern": "^[0-9]+(h|d)$" },
        "breakdowns":         { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/BreakdownDef" } },
        "compareWindow":      { "enum": ["previous_period"] }
      }
    },

    "CohortAnalysis": {
      "type": "object",
      "required": ["type", "cohortDefinition", "metric"],
      "additionalProperties": false,
      "properties": {
        "type":   { "const": "cohort" },
        "entity": { "enum": ["person_id"], "default": "person_id" },
        "cohortDefinition": {
          "type": "object",
          "oneOf": [
            {
              "required": ["firstEvent"],
              "additionalProperties": false,
              "properties": {
                "firstEvent": { "type": "string" },
                "period":     { "enum": ["day", "week", "month"] }
              }
            },
            {
              "required": ["property", "values"],
              "additionalProperties": false,
              "properties": {
                "property": { "type": "string" },
                "values":   { "type": "array", "minItems": 2, "maxItems": 10, "items": { "type": "string" } }
              }
            }
          ]
        },
        "metric": {
          "type": "object",
          "required": ["event", "aggregation"],
          "additionalProperties": false,
          "properties": {
            "event":       { "type": "string" },
            "aggregation": { "enum": ["count", "uniqueUsers", "avg", "sum"] },
            "intervals":   { "type": "array", "items": { "type": "integer" }, "maxItems": 8 }
          }
        },
        "maxCohorts": { "type": "integer", "minimum": 2, "maximum": 24, "default": 8 }
      }
    },

    "CustomAnalysis": {
      "type": "object",
      "required": ["type", "rawEvents"],
      "additionalProperties": false,
      "description": "Legacy raw-events mode. Preserved for v0Alpha migration only. Deprecated: use a typed analysis instead.",
      "$comment": "analysis.type=custom is not promoted in the UI wizard. maxEvents is hard-capped at 50.",
      "properties": {
        "type": { "const": "custom" },
        "rawEvents": {
          "type": "object",
          "required": ["events"],
          "additionalProperties": false,
          "properties": {
            "events":        { "oneOf": [{ "const": "*" }, { "type": "array", "minItems": 1, "items": { "type": "string" } }] },
            "maxEvents":     { "type": "integer", "minimum": 1, "maximum": 50 },
            "minEvents":     { "type": "integer", "minimum": 1 },
            "excludeFields": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "LLMConfig": {
      "type": "object",
      "required": ["promptTemplate"],
      "additionalProperties": false,
      "properties": {
        "promptTemplate": {
          "type": "string",
          "minLength": 10,
          "maxLength": 3000,
          "description": "Handlebars-style template. Use {{variableName}} to inject computed aggregates."
        },
        "systemMessage":   { "type": "string", "maxLength": 500 },
        "maxOutputTokens": { "type": "integer", "minimum": 100, "maximum": 2000, "default": 500 },
        "guardrails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "citeSources":     { "type": "boolean", "default": true },
            "noHallucination": { "type": "boolean", "default": true }
          }
        }
      }
    },

    "Privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "excludeProperties": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string" },
          "description": "Event property keys stripped before any query or LLM call."
        },
        "hashProperties": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string" },
          "description": "Event property keys SHA-256 hashed for pseudonymous linkage."
        }
      }
    }
  },
  "unevaluatedProperties": false
}
